# ════════════════════════════════════════════════════════════════════════════
#  AnimaShorts AI — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ════════════════════════════════════════════════════════════════════════════

# ── 1. GROQ (OBLIGATOIRE) ────────────────────────────────────────────────────
#  Compte gratuit : https://console.groq.com
GROQ_API_KEY=gsk_...

# ── 2. HUGGINGFACE (RECOMMANDÉ) ──────────────────────────────────────────────
#  Compte gratuit : https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...

# ── 3. EDGE-TTS (aucune clé nécessaire) ──────────────────────────────────────
EDGE_TTS_VOICE=en-US-GuyNeural
EDGE_TTS_RATE=-8%
EDGE_TTS_PITCH=-5Hz

# ── Redis ─────────────────────────────────────────────────────────────────────
#  Local Docker  : redis://redis:6379/0
#  Upstash (prod): rediss://default:MOT_DE_PASSE@URL.upstash.io:6379
REDIS_URL=redis://redis:6379/0

# ── URL publique du backend ──────────────────────────────────────────────────
#  Laisser vide en local.
#  En production Railway : mettre l'URL Railway ex: https://animashorts-backend.up.railway.app
PUBLIC_API_URL=

# ── Frontend ──────────────────────────────────────────────────────────────────
#  Local : http://localhost:8000
#  Production Vercel : laisser vide (vercel.json gère les rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Vidéo ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=/app/outputs
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
